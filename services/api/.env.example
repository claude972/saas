# --- Database (SQLAlchemy async / asyncpg) ---
DATABASE_URL=postgresql+asyncpg://openclaw:openclaw@localhost:5432/openclaw

# --- Auth / JWT ---
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Admin login (single user, checked by FastAPI) ---
ADMIN_EMAIL=admin@btp.local
ADMIN_PASSWORD=changeme

# --- Frontend origin (CORS) ---
FRONTEND_ORIGIN=http://localhost:3000

# --- LLM (Anthropic) ---
# Leave ANTHROPIC_API_KEY empty to run without the LLM: agents return marked stubs.
# ANTHROPIC_API_KEY=
OPENCLAW_MODEL=claude-opus-4-8
