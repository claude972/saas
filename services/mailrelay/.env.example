# Copier en .env sur le VPS et remplir les valeurs réelles.

# Domaine HTTPS du relais (un A record doit pointer vers l'IP du VPS).
RELAY_DOMAIN=relay.o-m2.fr

# Secret partagé avec le backend (identique à MAIL_RELAY_SECRET côté Railway).
RELAY_SECRET=remplacer-par-le-secret

# SMTP LWS (identifiants de la boîte d'envoi).
SMTP_HOST=mail.o-m2.fr
SMTP_PORT=465
SMTP_USER=devis@o-m2.fr
SMTP_PASSWORD=remplacer-par-le-mot-de-passe
SMTP_VERIFY_CERT=false
