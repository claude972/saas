# ─────────────────────────────────────────────────────────────
# Root environment — Docker / PostgreSQL
# Copy to .env if you want docker compose to pick up overrides.
# These values match docker-compose.yml defaults.
# ─────────────────────────────────────────────────────────────

# PostgreSQL (service "db" in docker-compose.yml)
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=openclaw
POSTGRES_DB=openclaw

# Connection string used by the backend (services/api/.env).
# Reminder only — set the real value in services/api/.env
# DATABASE_URL=postgresql+asyncpg://openclaw:openclaw@localhost:5432/openclaw
